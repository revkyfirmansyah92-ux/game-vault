{
    "version": 2,
    "builds": [
        { "src": "api/auth.ts", "use": "@vercel/node" },
        { "src": "vite.config.ts", "use": "@vercel/static-build", "config": { "distDir": "dist" } }
    ],
    "routes": [
        { "src": "/api/(.*)", "dest": "/api/auth.ts" },
        { "handle": "filesystem" },
        { "src": "/(.*)", "dest": "/index.html" }
    ]
}
