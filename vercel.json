{
    "version": 2,
    "builds": [
        { "src": "api/auth.ts", "use": "@vercel/node" },
        { "src": "package.json", "use": "@vercel/static-build", "config": { "distDir": "dist" } }
    ],
    "routes": [
        { "src": "/api/.*", "dest": "/api/auth.ts" },
        { "src": "/assets/(.*)", "dest": "/assets/$1" },
        { "src": "/(.*\\.(js|css|png|jpg|svg|ico|woff|woff2))", "dest": "/$1" },
        { "src": "/(.*)", "dest": "/index.html" }
    ]
}
